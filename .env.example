# Copy to .env and fill in real values

# SQLite for local dev, Postgres for prod (Neon/Supabase)
DATABASE_URL=sqlite:///./pricekenya.db
# DATABASE_URL=postgresql+psycopg://user:pass@host:5432/pricekenya

# Public base URL (used in emails, structured data)
BASE_URL=http://localhost:8000

# Affiliate tags
JUMIA_AFFILIATE_ID=

# Scraper politeness
SCRAPER_USER_AGENT="PriceKenyaBot/0.1 (+https://pricekenya.example)"
SCRAPER_REQUEST_DELAY_SECONDS=2

# Email alerts (optional, can defer)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERTS_FROM_EMAIL=alerts@pricekenya.example
