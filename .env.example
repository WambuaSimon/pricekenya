# Copy to .env and fill in real values

# SQLite for local dev, Postgres for prod (Neon/Supabase)
DATABASE_URL=sqlite:///./pricekenya.db
# DATABASE_URL=postgresql+psycopg://user:pass@host:5432/pricekenya

# Public base URL (used in emails, sitemap, JSON-LD)
BASE_URL=http://localhost:8000

# Affiliate tags
JUMIA_AFFILIATE_ID=

# Scraper politeness
SCRAPER_USER_AGENT="PriceKenyaBot/0.1 (+https://pricekenya.co.ke)"
SCRAPER_REQUEST_DELAY_SECONDS=2

# Resend transactional email (alerts/dispatcher.py). Get from resend.com/api-keys.
# Leave empty in local dev — the dispatcher will log-only instead of sending.
RESEND_API_KEY=
ALERTS_FROM_EMAIL="PriceKenya Alerts <alerts@pricekenya.co.ke>"

# HMAC key for signing one-click unsubscribe tokens. Required in prod.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=

# --- LLM matching fallback (Phase 0) ---
# When true and GEMINI_API_KEY is set, titles that the regex matcher can't
# parse fall through to Gemini 2.0 Flash (free tier). Off by default.
LLM_FALLBACK_ENABLED=false
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_TIMEOUT_SECONDS=3.0
# Per-category cap on LLM calls per UTC day. Guardrail against a broken
# scraper burning the free tier.
LLM_DAILY_CAP_PER_CATEGORY=500

# --- Embedding reconciliation (Phase 1) ---
# When true and sentence-transformers is installed (optional dep), the ingest
# pipeline runs a MiniLM cosine-similarity merge check before creating new
# products. Off by default.
EMBEDDING_ENABLED=false

# --- Admin ---
# Shared secret gating /admin/* routes (merge-review). Send via X-Admin-Key
# header. Leave empty in dev to disable the routes.
ADMIN_KEY=
